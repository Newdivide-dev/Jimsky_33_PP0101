<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" styleClass="root"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.music.MainController">

    <children>
        <VBox prefWidth="220.0" spacing="8.0" styleClass="side-bar"
              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding><Insets top="15" right="10" bottom="15" left="10"/></padding>
            <children>
                <Label text="SoundWave" style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold; -fx-padding: 0 0 15 0;"/>
                <Label fx:id="currentUserLabel" style="-fx-text-fill: #1DB954; -fx-font-size: 13; -fx-padding: 0 0 12 0;"/>

                <Button maxWidth="Infinity" onAction="#handleShowLibrary" text="📚 Библиотека" />
                <Button maxWidth="Infinity" onAction="#handleImport" text="➕ Импорт треков" />
                <Button maxWidth="Infinity" onAction="#handleCreatePlaylist" text="➕ Создать плейлист" />
                <Button maxWidth="Infinity" onAction="#handleDeleteTrack" text="🗑 Удалить трек" />
                <Button maxWidth="Infinity" onAction="#handleLogout" text="🚪 Выйти" style="-fx-text-fill: #ff5252;"/>

                <Label text="ПЛЕЙЛИСТЫ" style="-fx-text-fill: #888888; -fx-font-size: 11; -fx-padding: 15 0 4 0; -fx-font-weight: bold;"/>
                <ListView fx:id="playlistsListView" maxHeight="220.0" styleClass="playlist-list"/>
            </children>
        </VBox>

        <TextField fx:id="searchField" promptText="🔍 Поиск по названию или исполнителю..."
                   layoutX="235.0" layoutY="12.0" prefWidth="640.0" />

        <TableView fx:id="tracksTable" layoutX="235.0" layoutY="50.0" prefHeight="380.0" prefWidth="645.0"
                   AnchorPane.bottomAnchor="140.0" AnchorPane.leftAnchor="235.0"
                   AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="50.0">
            <columns>
                <TableColumn fx:id="titleColumn" prefWidth="340.0" text="НАЗВАНИЕ" />
                <TableColumn fx:id="artistColumn" prefWidth="300.0" text="ИСПОЛНИТЕЛЬ" />
            </columns>
        </TableView>

        <VBox alignment="CENTER" layoutY="480.0" prefHeight="120.0" spacing="6.0"
              style="-fx-background-color: #181818;"
              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <children>
                <Label fx:id="nowPlayingLabel" text="Выберите трек..."
                       style="-fx-text-fill: #1DB954; -fx-font-size: 13; -fx-font-weight: bold;"
                       maxWidth="700.0" />

                <HBox alignment="CENTER" spacing="10.0" prefWidth="700.0">
                    <Label fx:id="timeCurrent" text="0:00" style="-fx-text-fill: #b3b3b3;"/>
                    <Slider fx:id="progressSlider" prefWidth="520.0" />
                    <Label fx:id="timeTotal" text="0:00" style="-fx-text-fill: #b3b3b3;"/>
                </HBox>

                <HBox alignment="CENTER" spacing="20.0">

                    <Button fx:id="repeatButton" onAction="#handleRepeat" text="➡️"
                            style="-fx-background-color: transparent; -fx-font-size: 18; -fx-text-fill: #b3b3b3;"/>

                    <Button onAction="#handlePrev" text="⏮"
                            style="-fx-background-color: transparent; -fx-font-size: 20; -fx-text-fill: white;"/>

                    <Button fx:id="playButton" onAction="#handlePlayPause"
                            prefHeight="52.0" prefWidth="52.0" styleClass="play-button" text="▶" />

                    <Button onAction="#handleNext" text="⏭"
                            style="-fx-background-color: transparent; -fx-font-size: 20; -fx-text-fill: white;"/>

                    <HBox spacing="6.0" alignment="CENTER">
                        <Label text="🔊" style="-fx-text-fill: #b3b3b3;"/>
                        <Slider fx:id="volumeSlider" prefWidth="130.0" min="0" max="100" />
                    </HBox>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>